<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF xmlns="http://example.org/pizza/"
         xml:base="http://example.org/pizza/"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:skos="http://www.w3.org/2004/02/skos/core#"
         xmlns:term="http://example.org/pizza/term/">

    <owl:Ontology rdf:about="http://example.org/pizza/components">
        <rdfs:label xml:lang="zh">披萨组件本体</rdfs:label>
        <rdfs:comment xml:lang="zh">包含披萨的所有构成部分：饼底、酱汁、奶酪、配料及相关属性和实例。供应商、批次等业务属性统一定义在 PizzaComponent 上，子类自动继承。</rdfs:comment>
        <owl:imports rdf:resource="http://example.org/pizza/term"/>
    </owl:Ontology>

    <!-- ======================== -->
    <!-- 组件类层级 -->
    <!-- ======================== -->
    <owl:Class rdf:about="PizzaComponent">
        <rdfs:label xml:lang="zh">披萨组件</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="Crust">
        <rdfs:subClassOf rdf:resource="PizzaComponent"/>
        <rdfs:label xml:lang="zh">饼底</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Crust"/>
    </owl:Class>
    <owl:Class rdf:about="Sauce">
        <rdfs:subClassOf rdf:resource="PizzaComponent"/>
        <rdfs:label xml:lang="zh">酱汁</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Sauce"/>
    </owl:Class>
    <owl:Class rdf:about="Cheese">
        <rdfs:subClassOf rdf:resource="PizzaComponent"/>
        <rdfs:label xml:lang="zh">奶酪</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Cheese"/>
    </owl:Class>
    <owl:Class rdf:about="Topping">
        <rdfs:subClassOf rdf:resource="PizzaComponent"/>
        <rdfs:label xml:lang="zh">配料</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Topping"/>
    </owl:Class>

    <!-- 饼底子类 -->
    <owl:Class rdf:about="NeapolitanCrust">
        <rdfs:subClassOf rdf:resource="Crust"/>
        <rdfs:label xml:lang="zh">那不勒斯饼底</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/NeapolitanCrust"/>
    </owl:Class>
    <owl:Class rdf:about="NewYorkCrust">
        <rdfs:subClassOf rdf:resource="Crust"/>
        <rdfs:label xml:lang="zh">纽约饼底</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/NewYorkCrust"/>
    </owl:Class>
    <owl:Class rdf:about="ChicagoDeepDishCrust">
        <rdfs:subClassOf rdf:resource="Crust"/>
        <rdfs:label xml:lang="zh">芝加哥深盘饼底</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/ChicagoDeepDishCrust"/>
    </owl:Class>
    <owl:Class rdf:about="DetroitCrust">
        <rdfs:subClassOf rdf:resource="Crust"/>
        <rdfs:label xml:lang="zh">底特律饼底</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/DetroitCrust"/>
    </owl:Class>
    <owl:Class rdf:about="StLouisCrackerCrust">
        <rdfs:subClassOf rdf:resource="Crust"/>
        <rdfs:label xml:lang="zh">圣路易斯薄脆饼底</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/StLouisCrackerCrust"/>
    </owl:Class>
    <owl:Class rdf:about="SicilianCrust">
        <rdfs:subClassOf rdf:resource="Crust"/>
        <rdfs:label xml:lang="zh">西西里饼底</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/SicilianCrust"/>
    </owl:Class>
    <owl:Class rdf:about="RomanTondaCrust">
        <rdfs:subClassOf rdf:resource="Crust"/>
        <rdfs:label xml:lang="zh">罗马圆形薄脆饼底</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/RomanTondaCrust"/>
    </owl:Class>
    <owl:Class rdf:about="RomanAlTaglioCrust">
        <rdfs:subClassOf rdf:resource="Crust"/>
        <rdfs:label xml:lang="zh">罗马长条切块饼底</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/RomanAlTaglioCrust"/>
    </owl:Class>
    <owl:Class rdf:about="FrenchThinCrust">
        <rdfs:subClassOf rdf:resource="Crust"/>
        <rdfs:label xml:lang="zh">法式薄饼底</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/FrenchThinCrust"/>
    </owl:Class>
    <owl:Class rdf:about="ArgentinianThickCrust">
        <rdfs:subClassOf rdf:resource="Crust"/>
        <rdfs:label xml:lang="zh">阿根廷厚饼底</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/ArgentinianThickCrust"/>
    </owl:Class>

    <!-- 酱汁子类 -->
    <owl:Class rdf:about="TomatoSauce">
        <rdfs:subClassOf rdf:resource="Sauce"/>
        <rdfs:label xml:lang="zh">番茄红酱</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/TomatoSauce"/>
    </owl:Class>
    <owl:Class rdf:about="NeapolitanTomatoSauce">
        <rdfs:subClassOf rdf:resource="TomatoSauce"/>
        <rdfs:label xml:lang="zh">那不勒斯红酱</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/NeapolitanTomatoSauce"/>
    </owl:Class>
    <owl:Class rdf:about="AmericanTomatoSauce">
        <rdfs:subClassOf rdf:resource="TomatoSauce"/>
        <rdfs:label xml:lang="zh">美式红酱</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/AmericanTomatoSauce"/>
    </owl:Class>
    <owl:Class rdf:about="WhiteSauce">
        <rdfs:subClassOf rdf:resource="Sauce"/>
        <rdfs:label xml:lang="zh">白酱</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/WhiteSauce"/>
    </owl:Class>
    <owl:Class rdf:about="OtherSauce">
        <rdfs:subClassOf rdf:resource="Sauce"/>
        <rdfs:label xml:lang="zh">其他酱汁</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/OtherSauce"/>
    </owl:Class>

    <!-- 奶酪子类 -->
    <owl:Class rdf:about="BuffaloMozzarella">
        <rdfs:subClassOf rdf:resource="Cheese"/>
        <rdfs:label xml:lang="zh">水牛奶酪</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/BuffaloMozzarella"/>
    </owl:Class>
    <owl:Class rdf:about="LowMoistureMozzarella">
        <rdfs:subClassOf rdf:resource="Cheese"/>
        <rdfs:label xml:lang="zh">低水分马苏里拉</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/LowMoistureMozzarella"/>
    </owl:Class>
    <owl:Class rdf:about="Parmesan">
        <rdfs:subClassOf rdf:resource="Cheese"/>
        <rdfs:label xml:lang="zh">帕玛森芝士</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Parmesan"/>
    </owl:Class>
    <owl:Class rdf:about="ProvelCheese">
        <rdfs:subClassOf rdf:resource="Cheese"/>
        <rdfs:label xml:lang="zh">普罗维尔奶酪</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/ProvelCheese"/>
    </owl:Class>

    <!-- 配料子类 -->
    <owl:Class rdf:about="MeatTopping">
        <rdfs:subClassOf rdf:resource="Topping"/>
        <rdfs:label xml:lang="zh">肉类配料</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/MeatTopping"/>
    </owl:Class>
    <owl:Class rdf:about="VegetableTopping">
        <rdfs:subClassOf rdf:resource="Topping"/>
        <rdfs:label xml:lang="zh">蔬菜配料</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/VegetableTopping"/>
    </owl:Class>
    <owl:Class rdf:about="SeafoodTopping">
        <rdfs:subClassOf rdf:resource="Topping"/>
        <rdfs:label xml:lang="zh">海鲜配料</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/SeafoodTopping"/>
    </owl:Class>
    <owl:Class rdf:about="HerbTopping">
        <rdfs:subClassOf rdf:resource="Topping"/>
        <rdfs:label xml:lang="zh">香草配料</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/HerbTopping"/>
    </owl:Class>
    <owl:Class rdf:about="FruitTopping">
        <rdfs:subClassOf rdf:resource="Topping"/>
        <rdfs:label xml:lang="zh">水果配料</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/FruitTopping"/>
    </owl:Class>

    <!-- ======================== -->
    <!-- 对象属性 -->
    <!-- ======================== -->
    <owl:ObjectProperty rdf:about="hasCrust">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="Pizza"/>
        <rdfs:range rdf:resource="Crust"/>
        <rdfs:label xml:lang="zh">有饼底</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/hasCrust"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="hasSauce">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="Pizza"/>
        <rdfs:range rdf:resource="Sauce"/>
        <rdfs:label xml:lang="zh">有酱汁</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/hasSauce"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="hasCheese">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="Pizza"/>
        <rdfs:range rdf:resource="Cheese"/>
        <rdfs:label xml:lang="zh">有奶酪</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/hasCheese"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="hasTopping">
        <rdfs:domain rdf:resource="Pizza"/>
        <rdfs:range rdf:resource="Topping"/>
        <rdfs:label xml:lang="zh">有配料</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/hasTopping"/>
    </owl:ObjectProperty>

    <!-- 逆属性 -->
    <owl:ObjectProperty rdf:about="isCrustOf">
        <owl:inverseOf rdf:resource="hasCrust"/>
        <rdfs:domain rdf:resource="Crust"/>
        <rdfs:range rdf:resource="Pizza"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="isSauceOf">
        <owl:inverseOf rdf:resource="hasSauce"/>
        <rdfs:domain rdf:resource="Sauce"/>
        <rdfs:range rdf:resource="Pizza"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="isCheeseOf">
        <owl:inverseOf rdf:resource="hasCheese"/>
        <rdfs:domain rdf:resource="Cheese"/>
        <rdfs:range rdf:resource="Pizza"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="isToppingOf">
        <owl:inverseOf rdf:resource="hasTopping"/>
        <rdfs:domain rdf:resource="Topping"/>
        <rdfs:range rdf:resource="Pizza"/>
    </owl:ObjectProperty>

    <!-- 配料子属性 -->
    <owl:ObjectProperty rdf:about="hasMeatTopping">
        <rdfs:subPropertyOf rdf:resource="hasTopping"/>
        <rdfs:range rdf:resource="MeatTopping"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="hasVegetableTopping">
        <rdfs:subPropertyOf rdf:resource="hasTopping"/>
        <rdfs:range rdf:resource="VegetableTopping"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="hasSeafoodTopping">
        <rdfs:subPropertyOf rdf:resource="hasTopping"/>
        <rdfs:range rdf:resource="SeafoodTopping"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="hasHerbTopping">
        <rdfs:subPropertyOf rdf:resource="hasTopping"/>
        <rdfs:range rdf:resource="HerbTopping"/>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="hasFruitTopping">
        <rdfs:subPropertyOf rdf:resource="hasTopping"/>
        <rdfs:range rdf:resource="FruitTopping"/>
    </owl:ObjectProperty>

    <!-- ======================== -->
    <!-- 原有数据属性 -->
    <!-- ======================== -->
    <owl:DatatypeProperty rdf:about="crustThicknessMm">
        <rdfs:domain rdf:resource="Crust"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="zh">饼底厚度(毫米)</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/crustThickness"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="bakingTemperatureCelsius">
        <rdfs:domain rdf:resource="Crust"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="zh">烘烤温度(°C)</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/bakingTemperature"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="bakingTimeSeconds">
        <rdfs:domain rdf:resource="Crust"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="zh">烘烤时间(秒)</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/bakingTime"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="flourType">
        <rdfs:domain rdf:resource="Crust"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="zh">面粉种类</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/flourType"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="fermentation">
        <rdfs:domain rdf:resource="Crust"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="zh">发酵方式</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/fermentation"/>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="stackingOrder">
        <rdfs:domain rdf:resource="Pizza"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="zh">堆叠顺序</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/stackingOrder"/>
        <rdfs:comment xml:lang="zh">取值通常为 normal 或 inverted</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- ======================== -->
    <!-- 新增业务数据属性（定义在 PizzaComponent 上，子类继承） -->
    <!-- ======================== -->
    <owl:DatatypeProperty rdf:about="supplier">
        <rdfs:domain rdf:resource="PizzaComponent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="zh">供应商</rdfs:label>
        <rdfs:comment xml:lang="zh">披萨组件的原材料供应商名称</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="batchNumber">
        <rdfs:domain rdf:resource="PizzaComponent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="zh">批次</rdfs:label>
        <rdfs:comment xml:lang="zh">原材料的批次编号</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="price">
        <rdfs:domain rdf:resource="PizzaComponent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:label xml:lang="zh">价格</rdfs:label>
        <rdfs:comment xml:lang="zh">进货单价，单位：人民币元</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="purchaseDate">
        <rdfs:domain rdf:resource="PizzaComponent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label xml:lang="zh">进货日期</rdfs:label>
        <rdfs:comment xml:lang="zh">原材料采购入库日期</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="shelfLife">
        <rdfs:domain rdf:resource="PizzaComponent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="zh">保质期</rdfs:label>
        <rdfs:comment xml:lang="zh">保质期天数</rdfs:comment>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="status">
        <rdfs:domain rdf:resource="PizzaComponent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="zh">状态</rdfs:label>
        <rdfs:comment xml:lang="zh">当前状态，如：可用、过期、待检、停用等</rdfs:comment>
    </owl:DatatypeProperty>

    <!-- 自定义数据类型（饼底厚度范围） -->
    <rdfs:Datatype rdf:about="thinCrustRange">
        <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <owl:withRestrictions rdf:parseType="Collection">
            <rdf:Description>
                <xsd:minInclusive>3.0</xsd:minInclusive>
            </rdf:Description>
            <rdf:Description>
                <xsd:maxInclusive>7.0</xsd:maxInclusive>
            </rdf:Description>
        </owl:withRestrictions>
    </rdfs:Datatype>
    <rdfs:Datatype rdf:about="thickCrustRange">
        <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <owl:withRestrictions rdf:parseType="Collection">
            <rdf:Description>
                <xsd:minInclusive>20.0</xsd:minInclusive>
            </rdf:Description>
            <rdf:Description>
                <xsd:maxInclusive>80.0</xsd:maxInclusive>
            </rdf:Description>
        </owl:withRestrictions>
    </rdfs:Datatype>

    <!-- ======================== -->
    <!-- 配料个体 -->
    <!-- ======================== -->
    <owl:NamedIndividual rdf:about="Pepperoni">
        <rdf:type rdf:resource="MeatTopping"/>
        <rdfs:label xml:lang="zh">辣香肠</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Pepperoni"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="Salami">
        <rdf:type rdf:resource="MeatTopping"/>
        <rdfs:label xml:lang="zh">萨拉米</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Salami"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="Ham">
        <rdf:type rdf:resource="MeatTopping"/>
        <rdfs:label xml:lang="zh">火腿</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Ham"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="Bacon">
        <rdf:type rdf:resource="MeatTopping"/>
        <rdfs:label xml:lang="zh">培根</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Bacon"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="Anchovy">
        <rdf:type rdf:resource="MeatTopping"/>
        <rdf:type rdf:resource="SeafoodTopping"/>
        <rdfs:label xml:lang="zh">凤尾鱼</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Anchovy"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="ChickenTeriyaki">
        <rdf:type rdf:resource="MeatTopping"/>
        <rdfs:label xml:lang="zh">照烧鸡肉</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/ChickenTeriyaki"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="RoastDuck">
        <rdf:type rdf:resource="MeatTopping"/>
        <rdfs:label xml:lang="zh">烤鸭</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/RoastDuck"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="SpicyBeef">
        <rdf:type rdf:resource="MeatTopping"/>
        <rdfs:label xml:lang="zh">麻辣牛肉</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/SpicyBeef"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="Mushroom">
        <rdf:type rdf:resource="VegetableTopping"/>
        <rdfs:label xml:lang="zh">蘑菇</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Mushroom"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="Olive">
        <rdf:type rdf:resource="VegetableTopping"/>
        <rdfs:label xml:lang="zh">橄榄</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Olive"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="BellPepper">
        <rdf:type rdf:resource="VegetableTopping"/>
        <rdfs:label xml:lang="zh">彩椒</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/BellPepper"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="Onion">
        <rdf:type rdf:resource="VegetableTopping"/>
        <rdfs:label xml:lang="zh">洋葱</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Onion"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="Spinach">
        <rdf:type rdf:resource="VegetableTopping"/>
        <rdfs:label xml:lang="zh">菠菜</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Spinach"/>
    </owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="Corn">
        <rdf:type rdf:resource="VegetableTopping"/>
        <rdfs:label xml:lang="zh">玉米</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Corn"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="Shrimp">
        <rdf:type rdf:resource="SeafoodTopping"/>
