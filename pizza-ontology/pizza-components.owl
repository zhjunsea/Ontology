        <bakingTemperatureCelsius rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">465</bakingTemperatureCelsius>
        <bakingTimeSeconds rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">75</bakingTimeSeconds>
        <flourType>00细面粉</flourType>
