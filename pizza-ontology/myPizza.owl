<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF xmlns="http://example.org/pizza/"
         xml:base="http://example.org/pizza/"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:skos="http://www.w3.org/2004/02/skos/core#"
         xmlns:proc="http://example.org/pizza/process/">

    <owl:Ontology rdf:about="http://example.org/pizza">
        <rdfs:label xml:lang="zh">披萨主本体（完整修订版）</rdfs:label>
        <rdfs:comment xml:lang="zh">包含披萨抽象分类、所有具体披萨种类、工序关联及 Neapolitan 披萨的工序时长。依赖披萨组件本体、工序本体和 SKOS 术语库。</rdfs:comment>
        <owl:imports rdf:resource="file:///D:/work/Ontology/pizza-ontology/pizza-components.owl"/>
        <owl:imports rdf:resource="file:///D:/work/Ontology/pizza-ontology/pizza-processes.owl"/>
        <owl:imports rdf:resource="file:///D:/work/Ontology/pizza-ontology/pizza-terminology.ttl"/>
    </owl:Ontology>

    <!-- ======================== -->
    <!-- 披萨抽象类 -->
    <!-- ======================== -->
    <owl:Class rdf:about="Pizza">
        <rdfs:label xml:lang="zh">披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Pizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCrust"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="Crust"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- ======================== -->
    <!-- 酱汁分类抽象类 -->
    <!-- ======================== -->
    <owl:Class rdf:about="SauceCategoryPizza">
        <rdfs:subClassOf rdf:resource="Pizza"/>
        <rdfs:label xml:lang="zh">酱汁分类</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="TomatoBasedPizza">
        <rdfs:subClassOf rdf:resource="SauceCategoryPizza"/>
        <rdfs:label xml:lang="zh">番茄基底披萨</rdfs:label>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasSauce"/>
                <owl:someValuesFrom rdf:resource="TomatoSauce"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCheese"/>
                <owl:someValuesFrom rdf:resource="Cheese"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="WhitePizza">
        <rdfs:subClassOf rdf:resource="SauceCategoryPizza"/>
        <rdfs:label xml:lang="zh">白披萨</rdfs:label>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasSauce"/>
                <owl:someValuesFrom rdf:resource="WhiteSauce"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasSauce"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:complementOf rdf:resource="TomatoSauce"/>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCheese"/>
                <owl:someValuesFrom rdf:resource="Cheese"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="MarinaraPizza">
        <rdfs:subClassOf rdf:resource="SauceCategoryPizza"/>
        <rdfs:label xml:lang="zh">玛瑞纳拉披萨</rdfs:label>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasSauce"/>
                <owl:someValuesFrom rdf:resource="TomatoSauce"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCheese"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="NoSaucePizza">
        <rdfs:subClassOf rdf:resource="SauceCategoryPizza"/>
        <rdfs:label xml:lang="zh">无酱基底披萨</rdfs:label>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasSauce"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">0</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="Pizza">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <owl:Class rdf:about="TomatoBasedPizza"/>
                    <owl:Class rdf:about="WhitePizza"/>
                    <owl:Class rdf:about="MarinaraPizza"/>
                    <owl:Class rdf:about="NoSaucePizza"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>

    <owl:AllDisjointClasses>
        <owl:members rdf:parseType="Collection">
            <owl:Class rdf:about="TomatoBasedPizza"/>
            <owl:Class rdf:about="WhitePizza"/>
            <owl:Class rdf:about="MarinaraPizza"/>
            <owl:Class rdf:about="NoSaucePizza"/>
        </owl:members>
    </owl:AllDisjointClasses>

    <owl:Class rdf:about="WhiteSauce">
        <owl:disjointWith rdf:resource="TomatoSauce"/>
    </owl:Class>

    <!-- ======================== -->
    <!-- 地域分类抽象类 -->
    <!-- ======================== -->
    <owl:Class rdf:about="RegionalStylePizza">
        <rdfs:subClassOf rdf:resource="Pizza"/>
        <rdfs:label xml:lang="zh">地域分类</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="ItalianTraditionalPizza">
        <rdfs:subClassOf rdf:resource="RegionalStylePizza"/>
        <rdfs:label xml:lang="zh">意大利传统披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/ItalianTraditionalPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCrust"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="Crust"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasSauce"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="Sauce"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCheese"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="Cheese"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasTopping"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onClass rdf:resource="Topping"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="AmericanPizza">
        <rdfs:subClassOf rdf:resource="RegionalStylePizza"/>
        <rdfs:label xml:lang="zh">美式披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/AmericanPizza"/>
    </owl:Class>

    <owl:Class rdf:about="ChineseStylePizza">
        <rdfs:subClassOf rdf:resource="RegionalStylePizza"/>
        <rdfs:label xml:lang="zh">中式披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/ChineseStylePizza"/>
    </owl:Class>

    <owl:Class rdf:about="OtherGlobalPizza">
        <rdfs:subClassOf rdf:resource="RegionalStylePizza"/>
        <rdfs:label xml:lang="zh">全球其他流派披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/OtherGlobalPizza"/>
    </owl:Class>

    <owl:Class rdf:about="FlavorBasedPizza">
        <rdfs:subClassOf rdf:resource="Pizza"/>
        <rdfs:label xml:lang="zh">风味/食材分类披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/FlavorBasedPizza"/>
    </owl:Class>

    <!-- ======================== -->
    <!-- 具体披萨类（已按酱汁归类） -->
    <!-- ======================== -->
    <owl:Class rdf:about="NeapolitanPizza">
        <rdfs:subClassOf rdf:resource="ItalianTraditionalPizza"/>
        <rdfs:subClassOf rdf:resource="TomatoBasedPizza"/>
        <rdfs:label xml:lang="zh">那不勒斯披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/NeapolitanPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCrust"/>
                <owl:someValuesFrom rdf:resource="NeapolitanCrust"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasSauce"/>
                <owl:someValuesFrom rdf:resource="NeapolitanTomatoSauce"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCheese"/>
                <owl:someValuesFrom rdf:resource="BuffaloMozzarella"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCrust"/>
                <owl:allValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="crustThicknessMm"/>
                        <owl:allValuesFrom rdf:resource="thinCrustRange"/>
                    </owl:Restriction>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <!-- 制作工序约束（传统那不勒斯玛格丽特路径） -->
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasProcessStep"/>
                <owl:hasValue rdf:resource="proc:Task_DoughMix"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasProcessStep"/>
                <owl:hasValue rdf:resource="proc:Task_DoughFerment"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasProcessStep"/>
                <owl:hasValue rdf:resource="proc:Task_CrustForm"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasProcessStep"/>
                <owl:hasValue rdf:resource="proc:Task_TomatoSauce"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasProcessStep"/>
                <owl:hasValue rdf:resource="proc:Task_BaseCheese"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasProcessStep"/>
                <owl:hasValue rdf:resource="proc:Task_ToppingSpread"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasProcessStep"/>
                <owl:hasValue rdf:resource="proc:Task_Bake"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasProcessStep"/>
                <owl:hasValue rdf:resource="proc:Task_Decorate"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasProcessStep"/>
                <owl:hasValue rdf:resource="proc:Task_Finish"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="MargheritaPizza">
        <rdfs:subClassOf rdf:resource="NeapolitanPizza"/>
        <rdfs:label xml:lang="zh">玛格丽特披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/MargheritaPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasTopping"/>
                <owl:cardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:cardinality>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasTopping"/>
                <owl:hasValue rdf:resource="Basil"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="RomanTondaPizza">
        <rdfs:subClassOf rdf:resource="ItalianTraditionalPizza"/>
        <rdfs:subClassOf rdf:resource="TomatoBasedPizza"/>
        <rdfs:label xml:lang="zh">罗马圆形薄脆披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/RomanTondaPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCrust"/>
                <owl:someValuesFrom rdf:resource="RomanTondaCrust"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasSauce"/>
                <owl:someValuesFrom rdf:resource="NeapolitanTomatoSauce"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCheese"/>
                <owl:someValuesFrom rdf:resource="BuffaloMozzarella"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="RomanAlTaglioPizza">
        <rdfs:subClassOf rdf:resource="ItalianTraditionalPizza"/>
        <rdfs:subClassOf rdf:resource="TomatoBasedPizza"/>
        <rdfs:label xml:lang="zh">罗马切块披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/RomanAlTaglioPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCrust"/>
                <owl:someValuesFrom rdf:resource="RomanAlTaglioCrust"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasSauce"/>
                <owl:someValuesFrom rdf:resource="NeapolitanTomatoSauce"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCheese"/>
                <owl:someValuesFrom rdf:resource="BuffaloMozzarella"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="SicilianPizza">
        <rdfs:subClassOf rdf:resource="ItalianTraditionalPizza"/>
        <rdfs:subClassOf rdf:resource="TomatoBasedPizza"/>
        <rdfs:label xml:lang="zh">西西里披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/SicilianPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCrust"/>
                <owl:someValuesFrom rdf:resource="SicilianCrust"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasSauce"/>
                <owl:someValuesFrom rdf:resource="AmericanTomatoSauce"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCheese"/>
                <owl:someValuesFrom rdf:resource="LowMoistureMozzarella"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasTopping"/>
                <owl:hasValue rdf:resource="Onion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasTopping"/>
                <owl:hasValue rdf:resource="Anchovy"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="NewYorkPizza">
        <rdfs:subClassOf rdf:resource="AmericanPizza"/>
        <rdfs:subClassOf rdf:resource="TomatoBasedPizza"/>
        <rdfs:label xml:lang="zh">纽约薄饼披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/NewYorkPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCrust"/>
                <owl:someValuesFrom rdf:resource="NewYorkCrust"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasSauce"/>
                <owl:someValuesFrom rdf:resource="AmericanTomatoSauce"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCheese"/>
                <owl:someValuesFrom rdf:resource="LowMoistureMozzarella"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="ChicagoDeepDishPizza">
        <rdfs:subClassOf rdf:resource="AmericanPizza"/>
        <rdfs:label xml:lang="zh">芝加哥深盘披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/ChicagoDeepDishPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCrust"/>
                <owl:someValuesFrom rdf:resource="ChicagoDeepDishCrust"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="stackingOrder"/>
                <owl:hasValue>inverted</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasSauce"/>
                <owl:someValuesFrom rdf:resource="AmericanTomatoSauce"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCrust"/>
                <owl:allValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="crustThicknessMm"/>
                        <owl:allValuesFrom rdf:resource="thickCrustRange"/>
                    </owl:Restriction>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="DetroitPizza">
        <rdfs:subClassOf rdf:resource="AmericanPizza"/>
        <rdfs:label xml:lang="zh">底特律方形披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/DetroitPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCrust"/>
                <owl:someValuesFrom rdf:resource="DetroitCrust"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="stackingOrder"/>
                <owl:hasValue>inverted</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCheese"/>
                <owl:someValuesFrom rdf:resource="LowMoistureMozzarella"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="StLouisPizza">
        <rdfs:subClassOf rdf:resource="AmericanPizza"/>
        <rdfs:label xml:lang="zh">圣路易斯披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/StLouisPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCrust"/>
                <owl:someValuesFrom rdf:resource="StLouisCrackerCrust"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCheese"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="ProvelCheese"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="CaliforniaPizza">
        <rdfs:subClassOf rdf:resource="AmericanPizza"/>
        <rdfs:label xml:lang="zh">加州披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/CaliforniaPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasTopping"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <owl:Class rdf:about="SeafoodTopping"/>
                            <owl:Class rdf:about="FruitTopping"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="HawaiianPizza">
        <rdfs:subClassOf rdf:resource="AmericanPizza"/>
        <rdfs:label xml:lang="zh">夏威夷披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/HawaiianPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasTopping"/>
                <owl:hasValue rdf:resource="Ham"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasTopping"/>
                <owl:hasValue rdf:resource="Pineapple"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="PekingDuckPizza">
        <rdfs:subClassOf rdf:resource="ChineseStylePizza"/>
        <rdfs:label xml:lang="zh">烤鸭披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/PekingDuckPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasTopping"/>
                <owl:hasValue rdf:resource="RoastDuck"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="MalatBeefPizza">
        <rdfs:subClassOf rdf:resource="ChineseStylePizza"/>
        <rdfs:label xml:lang="zh">麻辣牛肉披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/MalatBeefPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasTopping"/>
                <owl:hasValue rdf:resource="SpicyBeef"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="DurianPizza">
        <rdfs:subClassOf rdf:resource="ChineseStylePizza"/>
        <rdfs:label xml:lang="zh">榴莲披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/DurianPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasTopping"/>
                <owl:hasValue rdf:resource="Durian"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="FrenchPizza">
        <rdfs:subClassOf rdf:resource="OtherGlobalPizza"/>
        <rdfs:label xml:lang="zh">法式披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/FrenchPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCrust"/>
                <owl:someValuesFrom rdf:resource="FrenchThinCrust"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasTopping"/>
                <owl:hasValue rdf:resource="Onion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasTopping"/>
                <owl:hasValue rdf:resource="Anchovy"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="ArgentinianPizza">
        <rdfs:subClassOf rdf:resource="OtherGlobalPizza"/>
        <rdfs:label xml:lang="zh">阿根廷披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/ArgentinianPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCrust"/>
                <owl:someValuesFrom rdf:resource="ArgentinianThickCrust"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCheese"/>
                <owl:someValuesFrom rdf:resource="LowMoistureMozzarella"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="JapaneseKoreanPizza">
        <rdfs:subClassOf rdf:resource="OtherGlobalPizza"/>
        <rdfs:label xml:lang="zh">日韩改良披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/JapaneseKoreanPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasSauce"/>
                <owl:someValuesFrom rdf:resource="OtherSauce"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasTopping"/>
                <owl:hasValue rdf:resource="ChickenTeriyaki"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasTopping"/>
                <owl:hasValue rdf:resource="Corn"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- 风味维度 -->
    <owl:Class rdf:about="WhiteSaucePizza">
        <rdfs:subClassOf rdf:resource="FlavorBasedPizza"/>
        <rdfs:subClassOf rdf:resource="WhitePizza"/>
        <rdfs:label xml:lang="zh">白酱披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/WhiteSaucePizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasSauce"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="WhiteSauce"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasSauce"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:complementOf rdf:resource="TomatoSauce"/>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="SeafoodPizza">
        <rdfs:subClassOf rdf:resource="FlavorBasedPizza"/>
        <rdfs:label xml:lang="zh">海鲜披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/SeafoodPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasTopping"/>
                <owl:someValuesFrom rdf:resource="SeafoodTopping"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <owl:Class rdf:about="VegetarianPizza">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="hasTopping"/>
                        <owl:allValuesFrom>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <owl:Class rdf:about="VegetableTopping"/>
                                    <owl:Class rdf:about="Cheese"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:allValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="FlavorBasedPizza"/>
        <rdfs:label xml:lang="zh">素食披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/VegetarianPizza"/>
    </owl:Class>

    <!-- 多继承示例（自动成为 WhitePizza） -->
    <owl:Class rdf:about="ItalianStyleWhiteSeafoodPizza">
        <rdfs:subClassOf rdf:resource="WhiteSaucePizza"/>
        <rdfs:subClassOf rdf:resource="SeafoodPizza"/>
        <rdfs:label xml:lang="zh">意式白酱海鲜披萨（融合）</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/ItalianStyleWhiteSeafoodPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="hasCrust"/>
                <owl:someValuesFrom rdf:resource="NeapolitanCrust"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- ======================== -->
    <!-- 新增属性：制作工序 -->
    <!-- ======================== -->
    <owl:ObjectProperty rdf:about="hasProcessStep">
        <rdfs:domain rdf:resource="Pizza"/>
        <rdfs:range rdf:resource="proc:ProcessStep"/>
        <rdfs:label xml:lang="zh">制作工序</rdfs:label>
        <rdfs:comment xml:lang="zh">披萨需要经历的工序步骤</rdfs:comment>
    </owl:ObjectProperty>

    <!-- ======================== -->
    <!-- 为工序个体补充操作时长（适用于那不勒斯玛格丽特披萨） -->
    <!-- ======================== -->
    <rdf:Description rdf:about="proc:Task_DoughMix">
        <proc:duration rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">15</proc:duration>
    </rdf:Description>
    <rdf:Description rdf:about="proc:Task_DoughFerment">
        <proc:duration rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">30</proc:duration>
    </rdf:Description>
    <rdf:Description rdf:about="proc:Task_CrustForm">
        <proc:duration rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">5</proc:duration>
    </rdf:Description>
    <rdf:Description rdf:about="proc:Task_TomatoSauce">
        <proc:duration rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</proc:duration>
    </rdf:Description>
    <rdf:Description rdf:about="proc:Task_BaseCheese">
        <proc:duration rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</proc:duration>
    </rdf:Description>
    <rdf:Description rdf:about="proc:Task_ToppingSpread">
        <proc:duration rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</proc:duration>
    </rdf:Description>
    <rdf:Description rdf:about="proc:Task_Bake">
        <proc:duration rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">2</proc:duration>
    </rdf:Description>
    <rdf:Description rdf:about="proc:Task_Decorate">
        <proc:duration rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</proc:duration>
    </rdf:Description>
    <rdf:Description rdf:about="proc:Task_Finish">
        <proc:duration rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">1</proc:duration>
    </rdf:Description>
</rdf:RDF>