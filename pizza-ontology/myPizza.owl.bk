        <skos:prefLabel xml:lang="zh">披萨</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/PizzaComponent -->

    <owl:Class rdf:about="http://example.org/pizza/PizzaComponent">
        <rdfs:label xml:lang="zh">披萨组件</rdfs:label>
