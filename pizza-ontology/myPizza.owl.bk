        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-06-24</terms:created>
        <terms:description xml:lang="zh">披萨领域核心业务术语的标准化定义，用于统一 OWL 本体及其他系统中的词义，实现同名同义、同义同名。</terms:description>
        <skos:prefLabel xml:lang="en">Pizza Business Terminology</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">披萨业务术语体系</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/AmericanPizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/AmericanPizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Pizza"/>
        <skos:definition xml:lang="zh">由意大利移民传入美国后发展出的披萨流派，饼底多样，芝士量大，配料丰富，注重饱腹感和创新。</skos:definition>
        <skos:prefLabel xml:lang="en">American Pizza</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">美式披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/AmericanTomatoSauce -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/AmericanTomatoSauce">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/TomatoSauce"/>
        <skos:definition xml:lang="zh">经过较长时间熬煮的浓稠番茄酱，口感更厚重，常用于美式披萨。</skos:definition>
        <skos:prefLabel xml:lang="en">American Tomato Sauce</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">美式红酱</skos:prefLabel>
    </owl:NamedIndividual>
    


