        <skos:prefLabel xml:lang="en">Buffalo Mozzarella</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">水牛奶酪</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/CaliforniaPizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/CaliforniaPizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/AmericanPizza"/>
        <skos:definition xml:lang="zh">创新美式披萨，擅用烟熏三文鱼、果蔬等新式食材，风味清淡新潮。</skos:definition>
        <skos:prefLabel xml:lang="zh">加州披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/Cheese -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/Cheese">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:definition xml:lang="zh">铺在酱汁之上的奶制品层，常用马苏里拉等，加热融化后提供奶香和拉丝质感。</skos:definition>
        <skos:prefLabel xml:lang="en">Cheese</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">奶酪</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/ChicagoDeepDishCrust -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/ChicagoDeepDishCrust">
