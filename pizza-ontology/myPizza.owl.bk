    <!-- http://example.org/pizza/term/ChineseStylePizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/ChineseStylePizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Pizza"/>
        <skos:definition xml:lang="zh">根据中国人口味改良的披萨，使用烤鸭、麻辣牛肉、榴莲等本土食材，口味偏向甜、辣、浓郁。</skos:definition>
