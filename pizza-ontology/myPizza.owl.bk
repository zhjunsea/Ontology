        <skos:broader rdf:resource="http://example.org/pizza/term/AmericanPizza"/>
        <skos:definition xml:lang="zh">美式深盘披萨，厚饼底内填大量奶酪和配料，上层覆盖厚番茄酱，倒置堆叠，饱腹感强。</skos:definition>
        <skos:prefLabel xml:lang="zh">芝加哥深盘披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


