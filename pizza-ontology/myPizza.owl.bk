        <skos:broader rdf:resource="http://example.org/pizza/term/MeatTopping"/>
        <skos:prefLabel xml:lang="en">Spicy Beef</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">麻辣牛肉</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/Spinach -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/Spinach">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/VegetableTopping"/>
        <skos:prefLabel xml:lang="en">Spinach</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">菠菜</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/Squid -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/Squid">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/SeafoodTopping"/>
        <skos:prefLabel xml:lang="en">Squid</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">鱿鱼</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/StLouisCrackerCrust -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/StLouisCrackerCrust">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Crust"/>
        <skos:definition xml:lang="zh">不使用酵母，薄而脆如饼干的特殊饼底，用于圣路易斯风格披萨。</skos:definition>
        <skos:prefLabel xml:lang="en">St. Louis Cracker Crust</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">圣路易斯薄脆饼底</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/StLouisPizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/StLouisPizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/AmericanPizza"/>
        <skos:definition xml:lang="zh">使用无酵母薄脆饼底和普罗维尔奶酪的美式披萨，通常切成小方块。</skos:definition>
        <skos:prefLabel xml:lang="zh">圣路易斯披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/TomatoSauce -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/TomatoSauce">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Sauce"/>
        <skos:definition xml:lang="zh">以番茄为主要原料的披萨酱汁，可生制或熬煮，提供酸甜底味。</skos:definition>
        <skos:prefLabel xml:lang="en">Tomato Sauce</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">番茄红酱</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/Topping -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/Topping">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:definition xml:lang="zh">披萨奶酪层之上的各类附加食材，包括肉类、海鲜、蔬菜、香草、水果等，丰富口感和风味。</skos:definition>
        <skos:prefLabel xml:lang="en">Topping</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">配料</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/VegetableTopping -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/VegetableTopping">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Topping"/>
        <skos:definition xml:lang="zh">以蔬菜（如蘑菇、洋葱、彩椒、菠菜等）作为披萨配料的一类。</skos:definition>
        <skos:prefLabel xml:lang="en">Vegetable Topping</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">蔬菜配料</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/VegetarianPizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/VegetarianPizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/FlavorBasedPizza"/>
        <skos:definition xml:lang="zh">不使用肉类或海鲜配料的披萨，仅用蔬菜、香草、水果和奶酪。</skos:definition>
        <skos:prefLabel xml:lang="zh">素食披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/WhiteSauce -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/WhiteSauce">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Sauce"/>
        <skos:definition xml:lang="zh">以奶油、蒜香、奶酪等为基础制成的白色酱汁，不含番茄，奶香浓郁。</skos:definition>
        <skos:prefLabel xml:lang="en">White Sauce</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">白酱</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/WhiteSaucePizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/WhiteSaucePizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/FlavorBasedPizza"/>
        <skos:definition xml:lang="zh">使用白酱作为酱汁基底的披萨，不含番茄酱，常见口味有奶油培根、菠菜奶酪等。</skos:definition>
        <skos:prefLabel xml:lang="zh">白酱披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/bakingTemperature -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/bakingTemperature">
