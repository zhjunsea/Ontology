        <skos:prefLabel xml:lang="zh">发酵方式</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/flourType -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/flourType">
