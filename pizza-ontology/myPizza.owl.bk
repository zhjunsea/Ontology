    <!-- http://example.org/pizza/RomanAlTaglioCrust -->

    <owl:Class rdf:about="http://example.org/pizza/RomanAlTaglioCrust">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/Crust"/>
        <rdfs:label xml:lang="zh">罗马长条切块饼底</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/RomanAlTaglioCrust"/>
        <skos:prefLabel xml:lang="zh">罗马长条切块饼底</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/RomanAlTaglioPizza -->

    <owl:Class rdf:about="http://example.org/pizza/RomanAlTaglioPizza">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/ItalianTraditionalPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasCheese"/>
                <owl:someValuesFrom rdf:resource="http://example.org/pizza/BuffaloMozzarella"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasCrust"/>
                <owl:someValuesFrom rdf:resource="http://example.org/pizza/RomanAlTaglioCrust"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasSauce"/>
                <owl:someValuesFrom rdf:resource="http://example.org/pizza/NeapolitanTomatoSauce"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="zh">罗马切块披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/RomanAlTaglioPizza"/>
        <skos:prefLabel xml:lang="zh">罗马切块披萨</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/RomanTondaCrust -->

    <owl:Class rdf:about="http://example.org/pizza/RomanTondaCrust">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/Crust"/>
        <rdfs:label xml:lang="zh">罗马圆形薄脆饼底</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/RomanTondaCrust"/>
        <skos:prefLabel xml:lang="zh">罗马圆形薄脆饼底</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/RomanTondaPizza -->

    <owl:Class rdf:about="http://example.org/pizza/RomanTondaPizza">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/ItalianTraditionalPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasCheese"/>
                <owl:someValuesFrom rdf:resource="http://example.org/pizza/BuffaloMozzarella"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasCrust"/>
                <owl:someValuesFrom rdf:resource="http://example.org/pizza/RomanTondaCrust"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasSauce"/>
                <owl:someValuesFrom rdf:resource="http://example.org/pizza/NeapolitanTomatoSauce"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="zh">罗马圆形薄脆披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/RomanTondaPizza"/>
        <skos:prefLabel xml:lang="zh">罗马圆形薄脆披萨</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/Sauce -->

    <owl:Class rdf:about="http://example.org/pizza/Sauce">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/PizzaComponent"/>
        <rdfs:label xml:lang="zh">酱汁</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Sauce"/>
        <skos:prefLabel xml:lang="zh">酱汁</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/SeafoodPizza -->

    <owl:Class rdf:about="http://example.org/pizza/SeafoodPizza">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/FlavorBasedPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasTopping"/>
                <owl:someValuesFrom rdf:resource="http://example.org/pizza/SeafoodTopping"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="zh">海鲜披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/SeafoodPizza"/>
        <skos:prefLabel xml:lang="zh">海鲜披萨</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/SeafoodTopping -->

    <owl:Class rdf:about="http://example.org/pizza/SeafoodTopping">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/Topping"/>
        <rdfs:label xml:lang="zh">海鲜配料</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/SeafoodTopping"/>
        <skos:prefLabel xml:lang="zh">海鲜配料</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/SicilianCrust -->

    <owl:Class rdf:about="http://example.org/pizza/SicilianCrust">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/Crust"/>
        <rdfs:label xml:lang="zh">西西里饼底</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/SicilianCrust"/>
        <skos:prefLabel xml:lang="zh">西西里饼底</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/SicilianPizza -->

    <owl:Class rdf:about="http://example.org/pizza/SicilianPizza">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/ItalianTraditionalPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasCheese"/>
                <owl:someValuesFrom rdf:resource="http://example.org/pizza/LowMoistureMozzarella"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasCrust"/>
                <owl:someValuesFrom rdf:resource="http://example.org/pizza/SicilianCrust"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasSauce"/>
                <owl:someValuesFrom rdf:resource="http://example.org/pizza/AmericanTomatoSauce"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasTopping"/>
                <owl:hasValue rdf:resource="http://example.org/pizza/Anchovy"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasTopping"/>
                <owl:hasValue rdf:resource="http://example.org/pizza/Onion"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="zh">西西里披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/SicilianPizza"/>
        <skos:prefLabel xml:lang="zh">西西里披萨</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/StLouisCrackerCrust -->

    <owl:Class rdf:about="http://example.org/pizza/StLouisCrackerCrust">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/Crust"/>
        <rdfs:label xml:lang="zh">圣路易斯薄脆饼底</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/StLouisCrackerCrust"/>
        <skos:prefLabel xml:lang="zh">圣路易斯薄脆饼底</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/StLouisPizza -->

    <owl:Class rdf:about="http://example.org/pizza/StLouisPizza">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/AmericanPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasCrust"/>
                <owl:someValuesFrom rdf:resource="http://example.org/pizza/StLouisCrackerCrust"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasSauce"/>
                <owl:someValuesFrom rdf:resource="http://example.org/pizza/StLouisTomatoSauce"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasCheese"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/pizza/ProvelCheese"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="zh">圣路易斯披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/StLouisPizza"/>
        <skos:prefLabel xml:lang="zh">圣路易斯披萨</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/StLouisTomatoSauce -->

    <owl:Class rdf:about="http://example.org/pizza/StLouisTomatoSauce">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/AmericanTomatoSauce"/>
        <rdfs:label xml:lang="zh">圣路易斯甜稠番茄酱</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/pizza/StrongMeatTopping -->

    <owl:Class rdf:about="http://example.org/pizza/StrongMeatTopping">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://example.org/pizza/Pepperoni"/>
                    <rdf:Description rdf:about="http://example.org/pizza/Salami"/>
                    <rdf:Description rdf:about="http://example.org/pizza/SpicyBeef"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/MeatTopping"/>
        <rdfs:label xml:lang="zh">浓烈红肉配料</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/pizza/SweetFruitTopping -->

    <owl:Class rdf:about="http://example.org/pizza/SweetFruitTopping">
        <owl:equivalentClass>
            <owl:Class>
                <owl:oneOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://example.org/pizza/Durian"/>
                    <rdf:Description rdf:about="http://example.org/pizza/Pineapple"/>
                </owl:oneOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/FruitTopping"/>
        <rdfs:label xml:lang="zh">甜水果配料</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/pizza/ThickCrust -->

    <owl:Class rdf:about="http://example.org/pizza/ThickCrust">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://example.org/pizza/ArgentinianThickCrust"/>
                    <rdf:Description rdf:about="http://example.org/pizza/ChicagoDeepDishCrust"/>
                    <rdf:Description rdf:about="http://example.org/pizza/DetroitCrust"/>
                    <rdf:Description rdf:about="http://example.org/pizza/RomanAlTaglioCrust"/>
                    <rdf:Description rdf:about="http://example.org/pizza/SicilianCrust"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/Crust"/>
        <rdfs:label xml:lang="zh">厚饼底</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/pizza/ThinCrust -->

    <owl:Class rdf:about="http://example.org/pizza/ThinCrust">
        <owl:equivalentClass>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://example.org/pizza/FrenchThinCrust"/>
                    <rdf:Description rdf:about="http://example.org/pizza/NeapolitanCrust"/>
                    <rdf:Description rdf:about="http://example.org/pizza/NewYorkCrust"/>
                    <rdf:Description rdf:about="http://example.org/pizza/RomanTondaCrust"/>
                    <rdf:Description rdf:about="http://example.org/pizza/StLouisCrackerCrust"/>
                </owl:unionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/Crust"/>
        <rdfs:label xml:lang="zh">薄饼底</rdfs:label>
    </owl:Class>
    


    <!-- http://example.org/pizza/TomatoSauce -->

    <owl:Class rdf:about="http://example.org/pizza/TomatoSauce">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/Sauce"/>
        <owl:disjointWith rdf:resource="http://example.org/pizza/WhiteSauce"/>
        <rdfs:label xml:lang="zh">番茄红酱</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/TomatoSauce"/>
        <skos:prefLabel xml:lang="zh">番茄红酱</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/Topping -->

    <owl:Class rdf:about="http://example.org/pizza/Topping">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/PizzaComponent"/>
        <rdfs:label xml:lang="zh">配料</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Topping"/>
        <skos:prefLabel xml:lang="zh">配料</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/VegetableTopping -->

    <owl:Class rdf:about="http://example.org/pizza/VegetableTopping">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/Topping"/>
        <rdfs:label xml:lang="zh">蔬菜配料</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/VegetableTopping"/>
        <skos:prefLabel xml:lang="zh">蔬菜配料</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/VegetarianPizza -->

    <owl:Class rdf:about="http://example.org/pizza/VegetarianPizza">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/FlavorBasedPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasTopping"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://example.org/pizza/FruitTopping"/>
                            <rdf:Description rdf:about="http://example.org/pizza/HerbTopping"/>
                            <rdf:Description rdf:about="http://example.org/pizza/VegetableTopping"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasTopping"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:complementOf>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://example.org/pizza/MeatTopping"/>
                                    <rdf:Description rdf:about="http://example.org/pizza/SeafoodTopping"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:complementOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="zh">素食披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/VegetarianPizza"/>
        <skos:prefLabel xml:lang="zh">素食披萨</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/WhiteSauce -->

    <owl:Class rdf:about="http://example.org/pizza/WhiteSauce">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/Sauce"/>
        <rdfs:label xml:lang="zh">白酱</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/WhiteSauce"/>
        <skos:prefLabel xml:lang="zh">白酱</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/WhiteSaucePizza -->

    <owl:Class rdf:about="http://example.org/pizza/WhiteSaucePizza">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/FlavorBasedPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasSauce"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:complementOf rdf:resource="http://example.org/pizza/TomatoSauce"/>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasTopping"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:complementOf rdf:resource="http://example.org/pizza/StrongMeatTopping"/>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasSauce"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://example.org/pizza/WhiteSauce"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="zh">白酱披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/WhiteSaucePizza"/>
        <skos:prefLabel xml:lang="zh">白酱披萨</skos:prefLabel>
    </owl:Class>
    


    <!-- http://www.w3.org/2004/02/skos/core#Concept -->

    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#Concept"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#ConceptScheme -->

    <owl:Class rdf:about="http://www.w3.org/2004/02/skos/core#ConceptScheme"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Individuals
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/pizza/Anchovy -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/Anchovy">
        <rdf:type rdf:resource="http://example.org/pizza/MeatTopping"/>
        <rdf:type rdf:resource="http://example.org/pizza/SeafoodTopping"/>
        <rdfs:label xml:lang="zh">凤尾鱼</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Anchovy"/>
        <skos:prefLabel xml:lang="zh">凤尾鱼</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/Bacon -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/Bacon">
        <rdf:type rdf:resource="http://example.org/pizza/MeatTopping"/>
        <rdfs:label xml:lang="zh">培根</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Bacon"/>
        <skos:prefLabel xml:lang="zh">培根</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/Basil -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/Basil">
        <rdf:type rdf:resource="http://example.org/pizza/HerbTopping"/>
        <rdfs:label xml:lang="zh">罗勒</rdfs:label>
