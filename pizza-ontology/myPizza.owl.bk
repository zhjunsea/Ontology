<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/pizza/"
     xml:base="http://example.org/pizza/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:skos="http://www.w3.org/2004/02/skos/core#"
     xmlns:term="http://example.org/pizza/term/"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http://example.org/pizza">
        <rdfs:comment xml:lang="zh">披萨知识本体，包含结构、地域流派与风味/食材两大正交分类维度，以及法定规范、物理限制、风味互斥三层约束。通过 skos:exactMatch 与 SKOS 术语文件关联。</rdfs:comment>
        <rdfs:label xml:lang="zh">披萨综合本体</rdfs:label>
        <skos:prefLabel xml:lang="zh">披萨综合本体</skos:prefLabel>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://purl.org/dc/terms/created -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/created"/>
    


    <!-- http://purl.org/dc/terms/description -->

    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#enumeration -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2001/XMLSchema#enumeration"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#maxInclusive -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2001/XMLSchema#maxInclusive"/>
    


    <!-- http://www.w3.org/2001/XMLSchema#minInclusive -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2001/XMLSchema#minInclusive"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#broader -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#broader"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#definition -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#definition"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#exactMatch -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#exactMatch"/>
    


    <!-- http://www.w3.org/2004/02/skos/core#prefLabel -->

    <owl:AnnotationProperty rdf:about="http://www.w3.org/2004/02/skos/core#prefLabel"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/pizza/thickCrustRange -->

    <rdfs:Datatype rdf:about="http://example.org/pizza/thickCrustRange">
        <rdfs:label xml:lang="zh">厚底厚度范围</rdfs:label>
    </rdfs:Datatype>
    


    <!-- http://example.org/pizza/thinCrustRange -->

    <rdfs:Datatype rdf:about="http://example.org/pizza/thinCrustRange">
        <rdfs:label xml:lang="zh">薄底厚度范围</rdfs:label>
    </rdfs:Datatype>
    


    <!-- http://www.w3.org/2001/XMLSchema#date -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/pizza/hasCheese -->

    <owl:ObjectProperty rdf:about="http://example.org/pizza/hasCheese">
        <owl:inverseOf rdf:resource="http://example.org/pizza/isCheeseOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/pizza/Pizza"/>
        <rdfs:range rdf:resource="http://example.org/pizza/Cheese"/>
        <rdfs:label xml:lang="zh">有奶酪</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Cheese"/>
        <skos:prefLabel xml:lang="zh">有奶酪</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://example.org/pizza/hasCrust -->

    <owl:ObjectProperty rdf:about="http://example.org/pizza/hasCrust">
        <owl:inverseOf rdf:resource="http://example.org/pizza/isCrustOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/pizza/Pizza"/>
        <rdfs:range rdf:resource="http://example.org/pizza/Crust"/>
        <rdfs:label xml:lang="zh">有饼底</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Crust"/>
        <skos:prefLabel xml:lang="zh">有饼底</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://example.org/pizza/hasFruitTopping -->

    <owl:ObjectProperty rdf:about="http://example.org/pizza/hasFruitTopping">
        <rdfs:subPropertyOf rdf:resource="http://example.org/pizza/hasTopping"/>
        <rdfs:range rdf:resource="http://example.org/pizza/FruitTopping"/>
        <rdfs:label xml:lang="zh">有水果配料</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/pizza/hasHerbTopping -->

    <owl:ObjectProperty rdf:about="http://example.org/pizza/hasHerbTopping">
        <rdfs:subPropertyOf rdf:resource="http://example.org/pizza/hasTopping"/>
        <rdfs:range rdf:resource="http://example.org/pizza/HerbTopping"/>
        <rdfs:label xml:lang="zh">有香草配料</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/pizza/hasMeatTopping -->

    <owl:ObjectProperty rdf:about="http://example.org/pizza/hasMeatTopping">
        <rdfs:subPropertyOf rdf:resource="http://example.org/pizza/hasTopping"/>
        <rdfs:range rdf:resource="http://example.org/pizza/MeatTopping"/>
        <rdfs:label xml:lang="zh">有肉类配料</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/pizza/hasSauce -->

    <owl:ObjectProperty rdf:about="http://example.org/pizza/hasSauce">
        <owl:inverseOf rdf:resource="http://example.org/pizza/isSauceOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://example.org/pizza/Pizza"/>
        <rdfs:range rdf:resource="http://example.org/pizza/Sauce"/>
        <rdfs:label xml:lang="zh">有酱汁</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Sauce"/>
        <skos:prefLabel xml:lang="zh">有酱汁</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://example.org/pizza/hasSeafoodTopping -->

    <owl:ObjectProperty rdf:about="http://example.org/pizza/hasSeafoodTopping">
        <rdfs:subPropertyOf rdf:resource="http://example.org/pizza/hasTopping"/>
        <rdfs:range rdf:resource="http://example.org/pizza/SeafoodTopping"/>
        <rdfs:label xml:lang="zh">有海鲜配料</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/pizza/hasTopping -->

    <owl:ObjectProperty rdf:about="http://example.org/pizza/hasTopping">
        <owl:inverseOf rdf:resource="http://example.org/pizza/isToppingOf"/>
        <rdfs:domain rdf:resource="http://example.org/pizza/Pizza"/>
        <rdfs:range rdf:resource="http://example.org/pizza/Topping"/>
        <rdfs:label xml:lang="zh">有配料</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Topping"/>
        <skos:prefLabel xml:lang="zh">有配料</skos:prefLabel>
    </owl:ObjectProperty>
    


    <!-- http://example.org/pizza/hasVegetableTopping -->

    <owl:ObjectProperty rdf:about="http://example.org/pizza/hasVegetableTopping">
        <rdfs:subPropertyOf rdf:resource="http://example.org/pizza/hasTopping"/>
        <rdfs:range rdf:resource="http://example.org/pizza/VegetableTopping"/>
        <rdfs:label xml:lang="zh">有蔬菜配料</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/pizza/isCheeseOf -->

    <owl:ObjectProperty rdf:about="http://example.org/pizza/isCheeseOf">
        <rdfs:domain rdf:resource="http://example.org/pizza/Cheese"/>
        <rdfs:range rdf:resource="http://example.org/pizza/Pizza"/>
        <rdfs:label xml:lang="zh">是奶酪之</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/pizza/isCrustOf -->

    <owl:ObjectProperty rdf:about="http://example.org/pizza/isCrustOf">
        <rdfs:domain rdf:resource="http://example.org/pizza/Crust"/>
        <rdfs:range rdf:resource="http://example.org/pizza/Pizza"/>
        <rdfs:label xml:lang="zh">是饼底之</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/pizza/isSauceOf -->

    <owl:ObjectProperty rdf:about="http://example.org/pizza/isSauceOf">
        <rdfs:domain rdf:resource="http://example.org/pizza/Sauce"/>
        <rdfs:range rdf:resource="http://example.org/pizza/Pizza"/>
        <rdfs:label xml:lang="zh">是酱汁之</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://example.org/pizza/isToppingOf -->

    <owl:ObjectProperty rdf:about="http://example.org/pizza/isToppingOf">
        <rdfs:domain rdf:resource="http://example.org/pizza/Topping"/>
        <rdfs:range rdf:resource="http://example.org/pizza/Pizza"/>
        <rdfs:label xml:lang="zh">是配料之</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/pizza/bakingTemperatureCelsius -->

    <owl:DatatypeProperty rdf:about="http://example.org/pizza/bakingTemperatureCelsius">
        <rdfs:domain rdf:resource="http://example.org/pizza/Crust"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="zh">烘烤温度(°C)</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/bakingTemperature"/>
        <skos:prefLabel xml:lang="zh">烘烤温度(°C)</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/pizza/bakingTimeSeconds -->

    <owl:DatatypeProperty rdf:about="http://example.org/pizza/bakingTimeSeconds">
        <rdfs:domain rdf:resource="http://example.org/pizza/Crust"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="zh">烘烤时间(秒)</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/bakingTime"/>
        <skos:prefLabel xml:lang="zh">烘烤时间(秒)</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/pizza/cheeseWeightGram -->

    <owl:DatatypeProperty rdf:about="http://example.org/pizza/cheeseWeightGram">
        <rdfs:domain rdf:resource="http://example.org/pizza/Cheese"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="zh">奶酪重量(克)</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/pizza/crustThicknessMm -->

    <owl:DatatypeProperty rdf:about="http://example.org/pizza/crustThicknessMm">
        <rdfs:domain rdf:resource="http://example.org/pizza/Crust"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
        <rdfs:label xml:lang="zh">饼底厚度(毫米)</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/crustThickness"/>
        <skos:prefLabel xml:lang="zh">饼底厚度(毫米)</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/pizza/fermentation -->

    <owl:DatatypeProperty rdf:about="http://example.org/pizza/fermentation">
        <rdfs:domain rdf:resource="http://example.org/pizza/Crust"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="zh">发酵方式</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/fermentation"/>
        <skos:prefLabel xml:lang="zh">发酵方式</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/pizza/flourType -->

    <owl:DatatypeProperty rdf:about="http://example.org/pizza/flourType">
        <rdfs:domain rdf:resource="http://example.org/pizza/Crust"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label xml:lang="zh">面粉种类</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/flourType"/>
        <skos:prefLabel xml:lang="zh">面粉种类</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/pizza/sauceWeightGram -->

    <owl:DatatypeProperty rdf:about="http://example.org/pizza/sauceWeightGram">
        <rdfs:domain rdf:resource="http://example.org/pizza/Sauce"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="zh">酱汁重量(克)</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/pizza/stackingOrder -->

    <owl:DatatypeProperty rdf:about="http://example.org/pizza/stackingOrder">
        <rdfs:domain rdf:resource="http://example.org/pizza/Pizza"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:onDatatype rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
                <owl:withRestrictions rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdfs:Datatype>
        </rdfs:range>
        <rdfs:label xml:lang="zh">堆叠顺序</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/stackingOrder"/>
        <skos:prefLabel xml:lang="zh">堆叠顺序</skos:prefLabel>
    </owl:DatatypeProperty>
    


    <!-- http://example.org/pizza/toppingTotalWeightGram -->

    <owl:DatatypeProperty rdf:about="http://example.org/pizza/toppingTotalWeightGram">
        <rdfs:domain rdf:resource="http://example.org/pizza/Topping"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="zh">配料总重(克)</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://example.org/pizza/AVPNNeapolitanPizza -->

    <owl:Class rdf:about="http://example.org/pizza/AVPNNeapolitanPizza">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/ItalianTraditionalPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasCrust"/>
                <owl:someValuesFrom rdf:resource="http://example.org/pizza/NeapolitanCrust"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasSauce"/>
                <owl:someValuesFrom rdf:resource="http://example.org/pizza/NeapolitanTomatoSauce"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasTopping"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://example.org/pizza/HerbTopping"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasTopping"/>
                <owl:allValuesFrom>
                    <owl:Class>
                        <owl:complementOf>
                            <owl:Class>
                                <owl:unionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://example.org/pizza/FruitTopping"/>
                                    <rdf:Description rdf:about="http://example.org/pizza/MeatTopping"/>
                                    <rdf:Description rdf:about="http://example.org/pizza/SeafoodTopping"/>
                                </owl:unionOf>
                            </owl:Class>
                        </owl:complementOf>
                    </owl:Class>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="zh">严格按照 AVPN 规范：饼底 3-7mm，生番茄酱，奶酪可选，配料仅限香草，禁止肉类、海鲜、水果。</rdfs:comment>
        <rdfs:label xml:lang="zh">AVPN 正统那不勒斯披萨</rdfs:label>
        <skos:prefLabel xml:lang="zh">AVPN 正统那不勒斯披萨</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/AmericanPizza -->

    <owl:Class rdf:about="http://example.org/pizza/AmericanPizza">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/Pizza"/>
        <rdfs:label xml:lang="zh">美式披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/AmericanPizza"/>
        <skos:prefLabel xml:lang="zh">美式披萨</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/AmericanTomatoSauce -->

    <owl:Class rdf:about="http://example.org/pizza/AmericanTomatoSauce">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/TomatoSauce"/>
        <rdfs:label xml:lang="zh">美式红酱</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/AmericanTomatoSauce"/>
        <skos:prefLabel xml:lang="zh">美式红酱</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/ArgentinianPizza -->

    <owl:Class rdf:about="http://example.org/pizza/ArgentinianPizza">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/OtherGlobalPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasCheese"/>
                <owl:someValuesFrom rdf:resource="http://example.org/pizza/LowMoistureMozzarella"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasCrust"/>
                <owl:someValuesFrom rdf:resource="http://example.org/pizza/ArgentinianThickCrust"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="zh">阿根廷披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/ArgentinianPizza"/>
        <skos:prefLabel xml:lang="zh">阿根廷披萨</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/ArgentinianThickCrust -->

    <owl:Class rdf:about="http://example.org/pizza/ArgentinianThickCrust">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/Crust"/>
        <rdfs:label xml:lang="zh">阿根廷厚饼底</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/ArgentinianThickCrust"/>
        <skos:prefLabel xml:lang="zh">阿根廷厚饼底</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/BuffaloMozzarella -->

    <owl:Class rdf:about="http://example.org/pizza/BuffaloMozzarella">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/Cheese"/>
        <rdfs:label xml:lang="zh">水牛奶酪</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/BuffaloMozzarella"/>
        <skos:prefLabel xml:lang="zh">水牛奶酪</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/CaliforniaPizza -->

    <owl:Class rdf:about="http://example.org/pizza/CaliforniaPizza">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/AmericanPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasTopping"/>
                <owl:someValuesFrom>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://example.org/pizza/FruitTopping"/>
                            <rdf:Description rdf:about="http://example.org/pizza/SeafoodTopping"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:someValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="zh">加州披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/CaliforniaPizza"/>
        <skos:prefLabel xml:lang="zh">加州披萨</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/Cheese -->

    <owl:Class rdf:about="http://example.org/pizza/Cheese">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/PizzaComponent"/>
        <rdfs:label xml:lang="zh">奶酪</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/Cheese"/>
        <skos:prefLabel xml:lang="zh">奶酪</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/ChicagoDeepDishCrust -->

    <owl:Class rdf:about="http://example.org/pizza/ChicagoDeepDishCrust">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/Crust"/>
        <rdfs:label xml:lang="zh">芝加哥深盘饼底</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/ChicagoDeepDishCrust"/>
        <skos:prefLabel xml:lang="zh">芝加哥深盘饼底</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/ChicagoDeepDishPizza -->

    <owl:Class rdf:about="http://example.org/pizza/ChicagoDeepDishPizza">
        <rdfs:subClassOf rdf:resource="http://example.org/pizza/AmericanPizza"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasCrust"/>
                <owl:someValuesFrom rdf:resource="http://example.org/pizza/ChicagoDeepDishCrust"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasSauce"/>
                <owl:someValuesFrom rdf:resource="http://example.org/pizza/AmericanTomatoSauce"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/hasCrust"/>
                <owl:allValuesFrom>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://example.org/pizza/crustThicknessMm"/>
                        <owl:allValuesFrom rdf:resource="http://example.org/pizza/thickCrustRange"/>
                    </owl:Restriction>
                </owl:allValuesFrom>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://example.org/pizza/stackingOrder"/>
                <owl:hasValue>inverted</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:label xml:lang="zh">芝加哥深盘披萨</rdfs:label>
        <skos:exactMatch rdf:resource="http://example.org/pizza/term/ChicagoDeepDishPizza"/>
        <skos:prefLabel xml:lang="zh">芝加哥深盘披萨</skos:prefLabel>
    </owl:Class>
    


