        <skos:definition xml:lang="zh">披萨底部的面饼层，由面粉、水、盐、酵母等原料经发酵和烘焙形成，提供承载和口感基础。</skos:definition>
        <skos:prefLabel xml:lang="en">Crust</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">饼底</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/DetroitCrust -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/DetroitCrust">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Crust"/>
        <skos:definition xml:lang="zh">用方形工业铁盘烤制，饼边因芝士焦化而酥脆，内部松软多孔的美式方形披萨饼底。</skos:definition>
        <skos:prefLabel xml:lang="en">Detroit Crust</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">底特律饼底</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/DetroitPizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/DetroitPizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/AmericanPizza"/>
        <skos:definition xml:lang="zh">美式方形披萨，铁盘烤制，边缘芝士焦脆，内部松软，酱汁常浇在芝士上方。</skos:definition>
        <skos:prefLabel xml:lang="zh">底特律方形披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/Durian -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/Durian">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/FruitTopping"/>
        <skos:prefLabel xml:lang="en">Durian</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">榴莲</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/DurianPizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/DurianPizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/ChineseStylePizza"/>
        <skos:prefLabel xml:lang="zh">榴莲披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/FlavorBasedPizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/FlavorBasedPizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Pizza"/>
        <skos:definition xml:lang="zh">按核心酱汁或主要配料类型划分的披萨类别，与地域维度正交，例如白酱披萨、海鲜披萨等。</skos:definition>
        <skos:prefLabel xml:lang="en">Flavor/Ingredient-Based Pizza</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">风味/食材分类披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/FrenchPizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/FrenchPizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/OtherGlobalPizza"/>
        <skos:prefLabel xml:lang="zh">法式披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/FrenchThinCrust -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/FrenchThinCrust">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Crust"/>
        <skos:definition xml:lang="zh">法式披萨常见的薄脆饼底。</skos:definition>
        <skos:prefLabel xml:lang="en">French Thin Crust</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">法式薄饼底</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/FruitTopping -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/FruitTopping">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Topping"/>
        <skos:definition xml:lang="zh">以水果（如菠萝、榴莲等）作为披萨配料的一类，常见于甜咸风味披萨。</skos:definition>
        <skos:prefLabel xml:lang="en">Fruit Topping</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">水果配料</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/Ham -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/Ham">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/MeatTopping"/>
        <skos:prefLabel xml:lang="en">Ham</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">火腿</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/HawaiianPizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/HawaiianPizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/AmericanPizza"/>
        <skos:definition xml:lang="zh">美式甜咸风味披萨，标志性配料为火腿和菠萝。</skos:definition>
        <skos:prefLabel xml:lang="zh">夏威夷披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/HerbTopping -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/HerbTopping">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Topping"/>
        <skos:definition xml:lang="zh">以芳香草本植物（如罗勒、牛至等）作为披萨配料的一类，常用于提味点缀。</skos:definition>
        <skos:prefLabel xml:lang="en">Herb Topping</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">香草配料</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/ItalianTraditionalPizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/ItalianTraditionalPizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Pizza"/>
        <skos:definition xml:lang="zh">起源并遵循意大利传统工艺制作的披萨，强调原产地配方、特定饼底与极简配料。</skos:definition>
        <skos:prefLabel xml:lang="en">Italian Traditional Pizza</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">意大利传统披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/JapaneseKoreanPizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/JapaneseKoreanPizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/OtherGlobalPizza"/>
        <skos:prefLabel xml:lang="zh">日韩改良披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/LowMoistureMozzarella -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/LowMoistureMozzarella">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Cheese"/>
        <skos:definition xml:lang="zh">经过脱水的马苏里拉奶酪，熔点高，拉伸性强，是美式披萨常用的奶酪。</skos:definition>
        <skos:prefLabel xml:lang="en">Low-Moisture Mozzarella</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">低水分马苏里拉</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/MalatBeefPizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/MalatBeefPizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/ChineseStylePizza"/>
        <skos:prefLabel xml:lang="zh">麻辣牛肉披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/MargheritaPizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/MargheritaPizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/NeapolitanPizza"/>
        <skos:definition xml:lang="zh">那不勒斯披萨的经典款，仅用番茄、水牛奶酪、罗勒，红白绿三色代表意大利国旗。</skos:definition>
        <skos:prefLabel xml:lang="en">Margherita Pizza</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">玛格丽特披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/MeatTopping -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/MeatTopping">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Topping"/>
        <skos:definition xml:lang="zh">以动物肉类（如香肠、火腿、鸡肉、牛肉等）作为披萨配料的一类。</skos:definition>
        <skos:prefLabel xml:lang="en">Meat Topping</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">肉类配料</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/Mushroom -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/Mushroom">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/VegetableTopping"/>
        <skos:prefLabel xml:lang="en">Mushroom</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">蘑菇</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/NeapolitanCrust -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/NeapolitanCrust">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Crust"/>
        <skos:definition xml:lang="zh">中心极薄（约5mm），边缘蓬松鼓胀，经450-480℃明火窑炉快速烘烤，表面产生豹斑和气孔的传统意式饼底。</skos:definition>
        <skos:prefLabel xml:lang="en">Neapolitan Crust</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">那不勒斯饼底</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/NeapolitanPizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/NeapolitanPizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/ItalianTraditionalPizza"/>
        <skos:definition xml:lang="zh">联合国教科文组织非物质文化遗产，使用那不勒斯饼底、生制红酱、水牛奶酪，极简配料，体现原料本味。</skos:definition>
        <skos:prefLabel xml:lang="en">Neapolitan Pizza</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">那不勒斯披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/NeapolitanTomatoSauce -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/NeapolitanTomatoSauce">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/TomatoSauce"/>
        <skos:definition xml:lang="zh">由圣马扎诺番茄碾碎，加盐、橄榄油、牛至，不经过熬煮制成的鲜制红酱，酸甜清爽。</skos:definition>
        <skos:prefLabel xml:lang="en">Neapolitan Tomato Sauce</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">那不勒斯红酱</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/NewYorkCrust -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/NewYorkCrust">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Crust"/>
        <skos:definition xml:lang="zh">手工拉伸的大尺寸薄饼，柔韧可对折，适合快餐手持食用，常见于美式薄饼披萨。</skos:definition>
        <skos:prefLabel xml:lang="en">New York Crust</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">纽约饼底</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/NewYorkPizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/NewYorkPizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/AmericanPizza"/>
        <skos:definition xml:lang="zh">美式经典薄饼披萨，大尺寸，饼底柔韧可对折，常用低水分马苏里拉和辣香肠。</skos:definition>
        <skos:prefLabel xml:lang="zh">纽约薄饼披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/Olive -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/Olive">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/VegetableTopping"/>
        <skos:prefLabel xml:lang="en">Olive</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">橄榄</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/Onion -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/Onion">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/VegetableTopping"/>
        <skos:prefLabel xml:lang="en">Onion</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">洋葱</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/Oregano -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/Oregano">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/HerbTopping"/>
        <skos:prefLabel xml:lang="en">Oregano</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">牛至</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/OtherGlobalPizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/OtherGlobalPizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Pizza"/>
        <skos:definition xml:lang="zh">其他国家和地区独特的披萨风格，如法式薄底、阿根廷厚芝士、日韩甜味改良等。</skos:definition>
        <skos:prefLabel xml:lang="en">Other Global Pizza</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">全球其他流派披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/OtherSauce -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/OtherSauce">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Sauce"/>
        <skos:definition xml:lang="zh">非传统红酱或白酱的调味基底，如日式沙拉酱、中式甜辣酱等。</skos:definition>
        <skos:prefLabel xml:lang="en">Other Sauce</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">其他酱汁</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/Parmesan -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/Parmesan">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Cheese"/>
        <skos:definition xml:lang="zh">硬质成熟的意大利奶酪，常刨丝使用，增添咸香风味。</skos:definition>
        <skos:prefLabel xml:lang="en">Parmesan</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">帕玛森芝士</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/PekingDuckPizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/PekingDuckPizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/ChineseStylePizza"/>
        <skos:prefLabel xml:lang="zh">烤鸭披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/Pepperoni -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/Pepperoni">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/MeatTopping"/>
        <skos:prefLabel xml:lang="en">Pepperoni</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">辣香肠</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/Pineapple -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/Pineapple">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/FruitTopping"/>
        <skos:prefLabel xml:lang="en">Pineapple</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">菠萝</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/Pizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/Pizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:definition xml:lang="en">A round, flattened base of dough topped with sauce, cheese, and various ingredients, baked to create a complete dish.</skos:definition>
        <skos:definition xml:lang="zh">一种源自意大利的圆形扁平面饼，通常由饼底、酱汁、奶酪及各种配料组成，经烘烤制成。</skos:definition>
        <skos:prefLabel xml:lang="en">Pizza</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/ProvelCheese -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/ProvelCheese">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Cheese"/>
        <skos:definition xml:lang="zh">一种由切达、瑞士奶酪等混合而成的加工奶酪，口感柔软易融，为圣路易斯披萨的特有奶酪。</skos:definition>
        <skos:prefLabel xml:lang="en">Provel Cheese</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">普罗维尔奶酪</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/RoastDuck -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/RoastDuck">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/MeatTopping"/>
        <skos:prefLabel xml:lang="en">Roast Duck</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">烤鸭</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/RomanAlTaglioCrust -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/RomanAlTaglioCrust">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Crust"/>
        <skos:definition xml:lang="zh">罗马风格长条厚饼底，内部多孔松软，用油较重，常切块按重量售卖。</skos:definition>
        <skos:prefLabel xml:lang="en">Roman Al Taglio Crust</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">罗马长条切块饼底</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/RomanAlTaglioPizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/RomanAlTaglioPizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/ItalianTraditionalPizza"/>
        <skos:prefLabel xml:lang="zh">罗马切块披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/RomanTondaCrust -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/RomanTondaCrust">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Crust"/>
        <skos:definition xml:lang="zh">罗马风格圆形薄脆饼底，口感薄脆。</skos:definition>
        <skos:prefLabel xml:lang="en">Roman Tonda Crust</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">罗马圆形薄脆饼底</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/RomanTondaPizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/RomanTondaPizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/ItalianTraditionalPizza"/>
        <skos:prefLabel xml:lang="zh">罗马圆形薄脆披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/Salami -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/Salami">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/MeatTopping"/>
        <skos:prefLabel xml:lang="en">Salami</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">萨拉米</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/Sauce -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/Sauce">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:definition xml:lang="zh">涂在饼底上的调味基底，通常分为番茄红酱、白酱等类型，决定披萨的基础风味。</skos:definition>
        <skos:prefLabel xml:lang="en">Sauce</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">酱汁</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/SeafoodPizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/SeafoodPizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/FlavorBasedPizza"/>
        <skos:definition xml:lang="zh">以虾仁、鱿鱼、蛤蜊等海鲜为主要配料的披萨，常见于地中海风味。</skos:definition>
        <skos:prefLabel xml:lang="zh">海鲜披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/SeafoodTopping -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/SeafoodTopping">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Topping"/>
        <skos:definition xml:lang="zh">以海产品（如虾仁、鱿鱼、蛤蜊等）作为披萨配料的一类。</skos:definition>
        <skos:prefLabel xml:lang="en">Seafood Topping</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">海鲜配料</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/Shrimp -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/Shrimp">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/SeafoodTopping"/>
        <skos:prefLabel xml:lang="en">Shrimp</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">虾仁</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/SicilianCrust -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/SicilianCrust">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/Crust"/>
        <skos:definition xml:lang="zh">方形厚饼，面团含油量高，结构蓬松如海绵，常见于西西里风格披萨。</skos:definition>
        <skos:prefLabel xml:lang="en">Sicilian Crust</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">西西里饼底</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/SicilianPizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/SicilianPizza">
        <rdf:type rdf:resource="http://www.w3.org/2004/02/skos/core#Concept"/>
        <skos:broader rdf:resource="http://example.org/pizza/term/ItalianTraditionalPizza"/>
        <skos:definition xml:lang="zh">方形厚底披萨，面团油润蓬松，铺大量番茄、洋葱、凤尾鱼等，咸香浓郁。</skos:definition>
        <skos:prefLabel xml:lang="zh">西西里披萨</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/SpicyBeef -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/SpicyBeef">
