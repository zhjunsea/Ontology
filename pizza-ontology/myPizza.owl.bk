        <skos:broader rdf:resource="http://example.org/pizza/term/Crust"/>
        <skos:definition xml:lang="zh">类似黄油酥皮的厚饼底，放在深圆烤盘中成型，厚度5-8cm，烘烤后酥松厚实。</skos:definition>
        <skos:prefLabel xml:lang="en">Chicago Deep-Dish Crust</skos:prefLabel>
        <skos:prefLabel xml:lang="zh">芝加哥深盘饼底</skos:prefLabel>
    </owl:NamedIndividual>
    


    <!-- http://example.org/pizza/term/ChicagoDeepDishPizza -->

    <owl:NamedIndividual rdf:about="http://example.org/pizza/term/ChicagoDeepDishPizza">
