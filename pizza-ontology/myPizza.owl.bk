        <skos:prefLabel xml:lang="zh">其他酱汁</skos:prefLabel>
    </owl:Class>
    


    <!-- http://example.org/pizza/Parmesan -->

    <owl:Class rdf:about="http://example.org/pizza/Parmesan">
