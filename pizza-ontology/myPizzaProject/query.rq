PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX skos: <http://www.w3.org/2004/02/skos/core#>
PREFIX proc: <http://example.org/pizza/process/>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
SELECT ?result WHERE {
  <http://example.org/pizza/NeapolitanPizza> rdfs:subClassOf* ?restriction .
  ?restriction owl:onProperty <http://example.org/pizza/hasProcessStep> ;
               owl:hasValue ?task .
  FILTER (STRENDS(STR(?task), "Task_DoughMix"))
  ?task <http://example.org/pizza/process/duration> ?result .
}
